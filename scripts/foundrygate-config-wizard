#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
env_file="${FOUNDRYGATE_ENV_FILE:-$repo_root/.env}"
python_bin="${FOUNDRYGATE_PYTHON:-python3}"
purpose="general"
format="yaml"

while [ $# -gt 0 ]; do
  case "$1" in
    --env-file)
      env_file="$2"
      shift 2
      ;;
    --purpose)
      purpose="$2"
      shift 2
      ;;
    --json)
      format="json"
      shift
      ;;
    --yaml)
      format="yaml"
      shift
      ;;
    *)
      printf 'unknown argument: %s\n' "$1" >&2
      exit 2
      ;;
  esac
done

export FOUNDRYGATE_WIZARD_ENV="$env_file"
export FOUNDRYGATE_WIZARD_PURPOSE="$purpose"
export FOUNDRYGATE_WIZARD_FORMAT="$format"

"$python_bin" - <<'PY'
import json
import os

from foundrygate.wizard import build_initial_config, render_initial_config_yaml

env_file = os.environ["FOUNDRYGATE_WIZARD_ENV"]
purpose = os.environ["FOUNDRYGATE_WIZARD_PURPOSE"]
render_format = os.environ["FOUNDRYGATE_WIZARD_FORMAT"]

if render_format == "json":
    print(json.dumps(build_initial_config(env_file=env_file, purpose=purpose), indent=2))
else:
    print(render_initial_config_yaml(env_file=env_file, purpose=purpose), end="")
PY
